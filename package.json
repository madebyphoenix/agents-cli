{
  "name": "@swarmify/agents-cli",
  "version": "1.13.4",
  "description": "One CLI for all your AI coding agents - versions, config, cloud dispatch, sessions, and teams",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./teams": {
      "types": "./dist/lib/teams/index.d.ts",
      "import": "./dist/lib/teams/index.js"
    }
  },
  "bin": {
    "agents": "dist/index.js",
    "ag": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phnx-labs/agents-cli.git"
  },
  "homepage": "https://agents-cli.sh",
  "bugs": {
    "url": "https://github.com/phnx-labs/agents-cli/issues"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "postinstall": "node scripts/postinstall.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "pretest": "./scripts/rebuild-sqlite.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agents",
    "cli",
    "dotfiles",
    "claude",
    "codex",
    "gemini",
    "cursor",
    "opencode",
    "mcp",
    "skills",
    "ai",
    "sync",
    "multi-agent"
  ],
  "author": "Phoenix Labs",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@xterm/headless": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "croner": "^9.0.0",
    "diff": "^7.0.0",
    "marked": "^17.0.3",
    "marked-terminal": "^7.3.0",
    "node-pty": "^1.1.0",
    "ora": "^8.1.0",
    "semver": "^7.6.0",
    "simple-git": "^3.27.0",
    "smol-toml": "^1.6.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^6.0.0",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
